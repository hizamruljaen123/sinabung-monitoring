# === SINABUNG MONITORING CONFIGURATION ===

# [1] System Mode
DEV_MODE=False

# [2] Database Configuration
# (If left empty, the app will try to read from ../mahameru-terminal-be/.env)
DB_HOST=127.0.0.1
DB_USER=root
DB_PASSWORD=
DB_NAME=asetpedia
DB_PORT=3306

# [3] Telegram Bot Alert Notification
# Provide your Telegram Bot Token and the Chat ID to receive early detection alerts for high RAM usage.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# [4] Alert Thresholds
# Set the RAM limit in Megabytes. If a service exceeds this limit, a Telegram alert is triggered.
RAM_ALERT_THRESHOLD=1500
